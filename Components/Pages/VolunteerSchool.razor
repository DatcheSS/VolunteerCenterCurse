@page "/volunteer-school"

<PageTitle>Школа волонтёра — ВЦ МИРЭА</PageTitle>

<div class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="bi bi-mortarboard me-2"></i>Школа волонтёра</h1>
        <p class="page-subtitle">Обучение и подготовка волонтёров</p>
    </div>
</div>

<section class="section-pad">
    <div class="container">
        <div class="school-announcement">
            <div class="school-icon">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <h2 class="school-title">Школа проводится в апреле</h2>
            <p class="school-subtitle">Заявки откроются в марте!</p>
            <div class="school-divider"></div>
            <p class="school-text">
                Школа волонтёра — это интенсивный образовательный курс для всех желающих стать частью нашей команды.
                В течение нескольких дней участники познакомятся с основами волонтёрской деятельности,
                узнают о направлениях работы центра и пройдут практические занятия.
            </p>

            <div class="school-topics">
                <div class="school-topic">
                    <i class="bi bi-book"></i>
                    <span>Основы волонтёрства</span>
                </div>
                <div class="school-topic">
                    <i class="bi bi-people-fill"></i>
                    <span>Командная работа</span>
                </div>
                <div class="school-topic">
                    <i class="bi bi-heart-pulse"></i>
                    <span>Первая помощь</span>
                </div>
                <div class="school-topic">
                    <i class="bi bi-chat-dots"></i>
                    <span>Коммуникации</span>
                </div>
                <div class="school-topic">
                    <i class="bi bi-tree"></i>
                    <span>Экология</span>
                </div>
                <div class="school-topic">
                    <i class="bi bi-camera"></i>
                    <span>Медиасопровождение</span>
                </div>
            </div>

            <div class="school-cta">
                <a href="/become-volunteer" class="btn-vc btn-vc-primary btn-lg">
                    <i class="bi bi-person-plus me-2"></i>Хочу стать волонтёром
                </a>
            </div>
        </div>
    </div>
</section>
