@page "/"
@inject AppDbContext Db
@inject EventService EventSvc
@using Microsoft.EntityFrameworkCore

<PageTitle>Волонтёрский центр РТУ МИРЭА</PageTitle>

<!-- Hero -->
<section class="hero-section">
    <div class="hero-bg"></div>
    <div class="hero-stars">
        <i class="star star1 bi bi-stars"></i>
        <i class="star star2 bi bi-star"></i>
        <i class="star star3 bi bi-star-fill"></i>
        <i class="star star4 bi bi-stars"></i>
        <i class="star star5 bi bi-star"></i>
    </div>
    <div class="container hero-content">
        <div class="hero-logo">
            <i class="bi bi-hearts hero-icon"></i>
        </div>
        <h1 class="hero-title">Волонтёрский центр<br /><span class="hero-accent">РТУ МИРЭА</span></h1>
        <p class="hero-subtitle">Помогаем тем, кто нуждается в поддержке. Меняем мир к лучшему вместе.</p>
        <div class="hero-actions">
            <a href="/become-volunteer" class="btn-vc btn-vc-primary btn-lg">
                <i class="bi bi-person-plus me-2"></i>Стать волонтёром
            </a>
            <a href="/request-volunteers" class="btn-vc btn-vc-outline btn-lg ms-3">
                <i class="bi bi-people me-2"></i>Запрос волонтёров
            </a>
        </div>
    </div>
</section>

<!-- О нас -->
<section class="section-pad">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-6">
                <div class="section-badge">О нас</div>
                <h2 class="section-title">Что такое волонтёрский центр?</h2>
                <p class="section-text">
                    Волонтёрский центр РТУ МИРЭА — это студенческое добровольческое объединение, которое действует с 2015 года.
                    Мы объединяем неравнодушных людей для помощи тем, кто в ней нуждается: пожилым, детям,
                    природе и городскому сообществу.
                </p>
                <p class="section-text">
                    Наши направления: социальное волонтёрство, экология, экспедиции, событийное волонтёрство
                    и медиасопровождение мероприятий. Каждый может найти своё место в нашей команде.
                </p>
                <div class="about-features">
                    <div class="about-feature"><i class="bi bi-check-circle-fill me-2"></i>Официальное объединение МИРЭА</div>
                    <div class="about-feature"><i class="bi bi-check-circle-fill me-2"></i>Волонтёрские книжки и зачёты</div>
                    <div class="about-feature"><i class="bi bi-check-circle-fill me-2"></i>Опытные кураторы</div>
                    <div class="about-feature"><i class="bi bi-check-circle-fill me-2"></i>Участие в федеральных проектах</div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="about-card">
                    <i class="bi bi-quote about-quote"></i>
                    <p class="about-quote-text">
                        «Волонтёрство — это не просто помощь другим. Это путь к себе, к новым знакомствам,
                        к открытию лучшей версии себя.»
                    </p>
                    <div class="about-author">
                        <strong>Наумов Александр Андреевич</strong>
                        <span>Председатель волонтёрского центра</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Статистика -->
<section class="stats-section">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number">100+</div>
                <div class="stat-label">Волонтёров</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">80+</div>
                <div class="stat-label">Мероприятий</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">25</div>
                <div class="stat-label">Экспедиций</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">18</div>
                <div class="stat-label">Организаторов</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">12</div>
                <div class="stat-label">Наград</div>
            </div>
        </div>
    </div>
</section>

<!-- Ближайшие мероприятия -->
<section class="section-pad">
    <div class="container">
        <div class="section-header">
            <div>
                <div class="section-badge">Скоро</div>
                <h2 class="section-title">Ближайшие мероприятия</h2>
            </div>
            <a href="/events" class="section-link">Все мероприятия <i class="bi bi-arrow-right ms-1"></i></a>
        </div>

        @if (upcomingEvents.Count > 0)
        {
            <div class="events-grid">
                @foreach (var ev in upcomingEvents)
                {
                    <div class="event-card">
                        <div class="event-card__header event-card__header--upcoming">
                            <div class="event-date-badge">
                                <span class="event-day">@ev.Date.Day</span>
                                <span class="event-month">@GetMonthName(ev.Date.Month)</span>
                            </div>
                            <span class="event-status event-status--upcoming">Предстоящее</span>
                        </div>
                        <div class="event-card__body">
                            <h3 class="event-title">@ev.Title</h3>
                            <p class="event-desc">@(ev.Description?.Length > 90 ? ev.Description[..90] + "..." : ev.Description)</p>
                            <div class="event-meta">
                                <span><i class="bi bi-clock me-1"></i>@ev.Date.ToString("HH:mm")</span>
                                <span><i class="bi bi-geo-alt me-1"></i>@(ev.Location.Length > 30 ? ev.Location[..30] + "…" : ev.Location)</span>
                            </div>
                            @if (ev.Curator != null)
                            {
                                <div class="event-curator">
                                    <i class="bi bi-person-badge me-1"></i>@ev.Curator.FullName
                                </div>
                            }
                        </div>
                        <div class="event-card__footer">
                            <a href="/events/@ev.Id" class="btn-vc btn-vc-primary btn-sm w-100">Подробнее</a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted-vc">Ближайшие мероприятия не запланированы. Следите за обновлениями!</p>
        }
    </div>
</section>

<!-- Руководство -->
@if (leaders.Count > 0)
{
    <section class="section-pad" style="background:var(--vc-surface);">
        <div class="container">
            <div class="section-badge" style="margin-bottom:.75rem;">Команда</div>
            <h2 class="section-title">Руководители волонтёрского центра</h2>
            <div class="leaders-grid">
                @foreach (var leader in leaders)
                {
                    <div class="leader-card">
                        <div class="leader-avatar">
                            @if (!string.IsNullOrEmpty(leader.AvatarUrl))
                            {
                                <img src="@leader.AvatarUrl" alt="@leader.FullName" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                            }
                            else
                            {
                                <i class="bi bi-person-badge"></i>
                            }
                        </div>
                        <div class="leader-name">@leader.FullName</div>
                        <div class="leader-position">@leader.Position</div>
                        <div class="leader-contacts">
                            @if (!string.IsNullOrEmpty(leader.Phone))
                            {
                                <div class="leader-contact"><i class="bi bi-telephone me-1"></i>@leader.Phone</div>
                            }
                            <div class="leader-contact"><i class="bi bi-envelope me-1"></i>@leader.Email</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- Контакты -->
<section class="contacts-section" id="contacts">
    <div class="container">
        <div class="section-badge" style="text-align:center;margin:0 auto 1rem;">Контакты</div>
        <h2 class="section-title text-center mb-4">Свяжитесь с нами</h2>
        <div class="row g-4 justify-content-center">
            <div class="col-md-3 col-6">
                <div class="contact-card">
                    <i class="bi bi-geo-alt contact-icon"></i>
                    <div class="contact-label">Адрес</div>
                    <div class="contact-value">пр. Вернадского, 78, Москва</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="contact-card">
                    <i class="bi bi-telephone contact-icon"></i>
                    <div class="contact-label">Телефон</div>
                    <div class="contact-value">+7 (958) 801-24-02</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="contact-card">
                    <i class="bi bi-envelope contact-icon"></i>
                    <div class="contact-label">Email</div>
                    <div class="contact-value">volunteer@sumirea.ru</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="contact-card">
                    <i class="bi bi-send contact-icon"></i>
                    <div class="contact-label">Telegram</div>
                    <div class="contact-value">&#64;vc_rtumirea</div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private List<Event> upcomingEvents = new();
    private List<VolunteerCenterCurse.Models.Specialist> leaders = new();

    protected override async Task OnInitializedAsync()
    {
        upcomingEvents = await EventSvc.GetUpcomingEventsAsync(3);
        leaders = await Db.Specialists.OrderBy(s => s.Id).ToListAsync();
    }

    private static string GetMonthName(int month) => month switch
    {
        1 => "ЯНВ", 2 => "ФЕВ", 3 => "МАР", 4 => "АПР",
        5 => "МАЙ", 6 => "ИЮН", 7 => "ИЮЛ", 8 => "АВГ",
        9 => "СЕН", 10 => "ОКТ", 11 => "НОЯ", _ => "ДЕК"
    };
}
