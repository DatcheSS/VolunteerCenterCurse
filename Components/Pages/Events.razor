@page "/events"
@inject EventService EventSvc
@inject NavigationManager Nav

<PageTitle>Все мероприятия — ВЦ МИРЭА</PageTitle>

<div class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="bi bi-calendar-event me-2"></i>Мероприятия месяца</h1>
        <p class="page-subtitle">Актуальные волонтёрские мероприятия</p>
    </div>
</div>

<section class="section-pad">
    <div class="container">
        <div class="legend-row">
            <span class="legend-item"><span class="legend-dot dot-green"></span>Предстоящее</span>
            <span class="legend-item"><span class="legend-dot dot-gray"></span>Прошедшее</span>
        </div>

        @if (!string.IsNullOrEmpty(searchQuery))
        {
            <div class="search-info">
                <i class="bi bi-search me-2"></i>Результаты поиска по «<strong>@searchQuery</strong>»
                <a href="/events" class="ms-2 clear-search"><i class="bi bi-x"></i> Сбросить</a>
            </div>
        }

        @if (events.Count == 0)
        {
            <div class="empty-state">
                <i class="bi bi-calendar-x"></i>
                <p>Мероприятий в этом месяце не найдено.</p>
            </div>
        }
        else
        {
            <div class="events-grid events-grid--full">
                @foreach (var ev in filteredEvents)
                {
                    bool isPast = ev.Date < DateTime.Now;
                    <div class="event-card @(isPast ? "event-card--past" : "event-card--upcoming")" @onclick="@(() => Nav.NavigateTo("/events/" + ev.Id))" style="cursor:pointer">
                        <div class="event-card__header @(isPast ? "event-card__header--past" : "event-card__header--upcoming")">
                            <div class="event-date-badge">
                                <span class="event-day">@ev.Date.Day</span>
                                <span class="event-month">@GetMonthName(ev.Date.Month)</span>
                            </div>
                            <span class="event-status @(isPast ? "event-status--past" : "event-status--upcoming")">
                                @(isPast ? "Прошедшее" : "Предстоящее")
                            </span>
                        </div>
                        <div class="event-card__body">
                            <h3 class="event-title">@ev.Title</h3>
                            <p class="event-desc">@(ev.Description?.Length > 80 ? ev.Description[..80] + "..." : ev.Description)</p>
                            <div class="event-meta">
                                <span><i class="bi bi-clock me-1"></i>@ev.Date.ToString("HH:mm")</span>
                                <span><i class="bi bi-geo-alt me-1"></i>@(ev.Location.Length > 25 ? ev.Location[..25] + "…" : ev.Location)</span>
                            </div>
                            @if (ev.Curator != null)
                            {
                                <div class="event-curator"><i class="bi bi-person-badge me-1"></i>@ev.Curator.FullName</div>
                            }
                        </div>
                        <div class="event-card__footer">
                            <span class="btn-vc @(isPast ? "btn-vc-ghost" : "btn-vc-primary") btn-sm w-100">Подробнее</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

@code {
    private List<Event> events = new();
    private string searchQuery = string.Empty;

    private IEnumerable<Event> filteredEvents => string.IsNullOrWhiteSpace(searchQuery)
        ? events
        : events.Where(e => e.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)
                          || (e.Description ?? "").Contains(searchQuery, StringComparison.OrdinalIgnoreCase)
                          || e.Location.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        events = await EventSvc.GetEventsThisMonthAsync();
    }

    protected override void OnParametersSet()
    {
        var uri = new Uri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        searchQuery = query.TryGetValue("q", out var val) ? val.ToString() : string.Empty;
    }

    private static string GetMonthName(int month) => month switch
    {
        1 => "ЯНВ", 2 => "ФЕВ", 3 => "МАР", 4 => "АПР",
        5 => "МАЙ", 6 => "ИЮН", 7 => "ИЮЛ", 8 => "АВГ",
        9 => "СЕН", 10 => "ОКТ", 11 => "НОЯ", _ => "ДЕК"
    };
}
